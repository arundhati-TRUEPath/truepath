PORT=4000
CORS_ORIGIN=http://localhost:3000

# Supabase — get from: Project Settings > API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service_role_key>

# OpenAI (needed for LLM followup question generation)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Model used for followup question generation. Options: gpt-4.1-mini, gpt-5.4-mini
OPENAI_FOLLOWUP_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Python embedding service (needed for Phase 3 pathways)
PYTHON_SERVICES_URL=http://localhost:8000
