PORT=4000
CORS_ORIGIN=http://localhost:3000

# Azure PostgreSQL Flexible Server — get from Azure Portal > truepath-db > Connection strings
DATABASE_URL=postgresql://<admin-user>:<password>@<host>.postgres.database.azure.com:5432/postgres?sslmode=require

# OpenAI (needed for LLM followup question generation)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Model used for followup question generation. Options: gpt-4.1-mini, gpt-5.4-mini
OPENAI_FOLLOWUP_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Python embedding service (needed for Phase 3 pathways)
PYTHON_SERVICES_URL=http://localhost:8000
