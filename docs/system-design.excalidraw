    {
      "id": "vQQTCCzpSAeMo5cmgFDtd",
      "type": "text",
      "x": 64.92491925546551,
      "y": 812.0300322978138,
      "width": 255.0115509033203,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0XM",
      "roundness": null,
      "seed": 645310375,
      "version": 259,
      "versionNonce": 1424394055,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1778992118511,
      "link": null,
      "locked": false,
      "text": "1. Initial fetch (FE→BE)\n2. Init Question Service\n3. Pull questions+choices from DB\n4. Submit 7 Q+R (FE→BE)\n5. Send 7 Q+R + Sys Prompt to LLM\n6. LLM returns 3 more Q+choices\n7. Submit 10 Q+R (FE→BE)\n8. Send 10 Q+R + Sys Prompt (BE→LLM)\n9. LLM→BE: gen 6 high conf &\n 3 low conf skills\n10. Skill selection (FE→BE)\n11. Send skill data to LLM Embedding\n12. Similarity search on Vector DB\n13. Return vectorized pathways + sim score\n14. Convert vector to text (LLM Embed)",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Initial fetch (FE→BE)\n2. Init Question Service\n3. Pull questions+choices from DB\n4. Submit 7 Q+R (FE→BE)\n5. Send 7 Q+R + Sys Prompt to LLM\n6. LLM returns 3 more Q+choices\n7. Submit 10 Q+R (FE→BE)\n8. Send 10 Q+R + Sys Prompt (BE→LLM)\n9. LLM→BE: gen 6 high conf &\n 3 low conf skills\n10. Skill selection (FE→BE)\n11. Send skill data to LLM Embedding\n12. Similarity search on Vector DB\n13. Return vectorized pathways + sim score\n14. Convert vector to text (LLM Embed)",
      "autoResize": true,
      "lineHeight": 1.25
    },
